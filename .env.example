# Copy this file to .env and fill in values. Never commit .env.

# --- Runtime ---
ENV=dev                          # dev | staging | prod
LOG_LEVEL=INFO

# --- Provider selection ---
# azure = Azure AI Foundry (OpenAI-compatible /openai/v1, call by deployment name)
# also: azure_openai (classic) | openai | anthropic | claude_code | ollama
LLM_PROVIDER=azure
# Model = the DEPLOYMENT name for azure (e.g. gpt-4o), else the model id. Any model
# you deploy in Foundry is callable by name — no code change ("all models open").
LLM_MODEL=gpt-4o

# --- Model proxy (optional) ---
# Route ALL models through one OpenAI-compatible gateway (e.g. a LiteLLM proxy
# or enterprise gateway). When LLM_PROXY_BASE_URL is set it OVERRIDES the
# per-provider settings below, and the benchmark compares models behind this
# single endpoint. Leave blank to use the native providers directly.
LLM_PROXY_BASE_URL=              # e.g. https://gateway.internal/v1
LLM_PROXY_API_KEY=

# --- Azure AI Foundry / Azure OpenAI ---
# For LLM_PROVIDER=azure, set ENDPOINT (Foundry resource) + API_KEY; build_llm
# derives the OpenAI-compatible base as {ENDPOINT}/openai/v1 and calls by model name.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.services.ai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o   # used by the classic azure_openai provider

# --- OpenAI direct (if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=

# --- Anthropic (if LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=

# --- Google Gemini (LLM_PROVIDER=google; required for the Google tier of the
# test matrix — Gemini is NOT served via Azure Foundry) ---
GOOGLE_API_KEY=

# --- Copilot proxy (LLM_PROVIDER=copilot; a local Anthropic-style gateway that
# fronts many models, e.g. a LiteLLM/copilot proxy). Used by `--backend copilot`. ---
COPILOT_PROXY_BASE_URL=http://localhost:4000
COPILOT_PROXY_API_KEY=sk-dummy

# --- TPO tool backends ---
# Leave base URLs blank to use deterministic mock tools (dev/test/eval). Set
# them to call the live services over HTTP (Bearer <key> auth).
CDT_BASE_URL=                    # CDT TextToSQL agent, e.g. https://cdt.internal/api
CDT_API_KEY=
CDT_TIMEOUT_S=30
ERDC_BASE_URL=                   # ERDC Optimizer API, e.g. https://erdc.internal/api
ERDC_API_KEY=
ERDC_TIMEOUT_S=30
TOOL_MAX_RETRIES=2

# --- Per-agent overrides (optional — falls back to LLM_MODEL if empty) ---
ORCHESTRATOR_MODEL=gpt-4o
SUBAGENT_A_MODEL=gpt-4o-mini
SUBAGENT_B_MODEL=gpt-4o-mini

# --- FastAPI ---
DEBUG=false
