<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Sequence Diagram - Clean Alt">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Lifelines -->
        <mxCell id="user" value="User" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="120" height="700" as="geometry"/>
        </mxCell>

        <mxCell id="orc" value="Orchestrator" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="260" y="20" width="140" height="700" as="geometry"/>
        </mxCell>

        <mxCell id="subA" value="SubAgent A (Data)" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="480" y="20" width="160" height="700" as="geometry"/>
        </mxCell>

        <mxCell id="subD" value="SubAgent D (Explain)" style="shape=umlLifeline;" vertex="1" parent="1">
          <mxGeometry x="720" y="20" width="180" height="700" as="geometry"/>
        </mxCell>

        <!-- Activation bars -->
        <mxCell id="actOrc" style="shape=rectangle;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="324" y="80" width="12" height="540" as="geometry"/>
        </mxCell>

        <mxCell id="actA" style="shape=rectangle;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="554" y="220" width="12" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="actD" style="shape=rectangle;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="794" y="400" width="12" height="120" as="geometry"/>
        </mxCell>

        <!-- Messages (bem espaçadas verticalmente) -->
        <mxCell id="m1" value="1. User Query" style="endArrow=block;" edge="1" parent="1" source="user" target="orc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="120" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ALT BOX (manual) -->
        <mxCell id="altBox" value="alt" style="shape=rectangle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="180" width="700" height="300" as="geometry"/>
        </mxCell>

        <!-- Divider -->
        <mxCell id="altDivider" style="shape=line;" vertex="1" parent="1">
          <mxGeometry x="240" y="330" width="700" height="1" as="geometry"/>
        </mxCell>

        <!-- Conditions -->
        <mxCell id="cond1" value="[intent = data]" style="text;align=left;" vertex="1" parent="1">
          <mxGeometry x="250" y="190" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="cond2" value="[intent = explain]" style="text;align=left;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Branch A -->
        <mxCell id="m2" value="2a. Call SubAgent A" style="endArrow=block;" edge="1" parent="1" source="orc" target="subA">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m3" value="3a. Data Result" style="dashed=1;endArrow=open;" edge="1" parent="1" source="subA" target="orc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Branch D -->
        <mxCell id="m4" value="2b. Call SubAgent D" style="endArrow=block;" edge="1" parent="1" source="orc" target="subD">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="390" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="m5" value="3b. Explanation Result" style="dashed=1;endArrow=open;" edge="1" parent="1" source="subD" target="orc">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="440" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Final -->
        <mxCell id="m6" value="4. Final Response" style="endArrow=block;" edge="1" parent="1" source="orc" target="user">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="0" y="550" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>